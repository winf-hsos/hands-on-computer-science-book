        "        led.set_rgb_value(brightness, brightness, brightness)\n",
        "    if color == \"yellow\":\n",
        "        led.set_rgb_value(brightness, brightness, 0)\n",
        "    if color == \"green\":\n",
        "        led.set_rgb_value(0, brightness, 0)\n",
