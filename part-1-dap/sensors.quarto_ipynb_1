        "from collections import deque\n",
        "import numpy as np\n",
        "import neurokit2 as nk\n",
        "\n",
        "fps = 20\n",
        "buf = deque(maxlen=10 * fps)\n",
        "\n",
        "def bpm_live(new_sample):\n",
        "    buf.append(new_sample)\n",
        "    if len(buf) < buf.maxlen:\n",
        "        return None\n",
        "\n",
        "    window = np.asarray(buf, dtype=float)\n",
        "    signals, _ = nk.ppg_process(window, sampling_rate=fps)\n",
        "\n",
        "    # robust: Median der letzten 3 Sekunden\n",
        "    bpm = np.nanmedian(signals[\"PPG_Rate\"].to_numpy()[-3*fps:])\n",
